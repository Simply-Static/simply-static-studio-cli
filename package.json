{
  "name": "@simply-static/static-studio",
  "version": "0.1.4",
  "description": "Command-line interface for Static Studio hosting workflows.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Simply-Static/simply-static-studio-cli.git"
  },
  "bugs": {
    "url": "https://github.com/Simply-Static/simply-static-studio-cli/issues"
  },
  "homepage": "https://github.com/Simply-Static/simply-static-studio-cli#readme",
  "keywords": [
    "static-studio",
    "simply-static",
    "cli",
    "wordpress",
    "hosting"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "static-studio": "dist/cli.js",
    "sss": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup src/cli.ts src/index.ts --format esm --dts --clean",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm test"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.637.0",
    "@aws-sdk/lib-storage": "^3.637.0",
    "@supabase/supabase-js": "^2.46.2",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.15",
    "tsup": "^8.2.4",
    "tsx": "^4.22.4",
    "typescript": "^5.5.4",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
